{
  "name": "sistema-almacen",
  "version": "1.0.0",
  "description": "Sistema de Gestión de Almacén",
  "private": true,
  "workspaces": [
    "apps/electron",
    "apps/electron/renderer",
    "apps/api",
    "packages/shared-types",
    "packages/shared-schemas",
    "packages/shared-utils"
  ],
  "scripts": {
    "dev": "npm run dev:clean && concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:full": "npm run dev:clean && concurrently \"npm run dev:api\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:clean": "fuser -k 3000/tcp || true && fuser -k 5173/tcp || true",
    "dev:api": "npm run dev --workspace=@sistema-almacen/api",
    "dev:renderer": "npm run dev --workspace=@sistema-almacen/renderer",
    "dev:electron": "wait-on http://localhost:5173 && npm run dev --workspace=@sistema-almacen/electron",
    "migrate:supabase": "npm run migrate:mysql-to-postgres:init --workspace=@sistema-almacen/api",
    "verify:migrate:supabase": "npm run verify:mysql-to-postgres --workspace=@sistema-almacen/api",
    "stock:rebuild": "npm run stock:rebuild --workspace=@sistema-almacen/api",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "npm run build --workspace=@sistema-almacen/renderer",
    "build:electron": "npm run build --workspace=@sistema-almacen/electron"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  }
}