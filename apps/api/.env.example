# ============================================
# CONFIGURACIÓN DE BASE DE DATOS (PostgreSQL / Supabase)
# ============================================
#
# Opción 1 - URL de conexión (recomendado para Supabase):
# Conexión directa (requiere IPv6):
#   DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.xxxxx.supabase.co:5432/postgres
# Si tu red NO tiene IPv6, usa la URL del POOLER desde Dashboard → Connect → Session/Transaction pooler:
#   DATABASE_URL=postgresql://postgres.PROJECT_REF:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.jdcqstaoqximbmqbwjwy:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
#
# Opción 2 - Variables por separado (si no usas DATABASE_URL):
# DB_HOST=db.xxxxx.supabase.co
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=tu_password
# DB_NAME=postgres
#
# SSL: Supabase usa SSL. Para desactivar (solo desarrollo local): DB_SSL=false
# DB_SSL=false

# Sincronizar esquema automáticamente (recomendado: false)
DB_SYNC=false

# Mostrar logs de SQL en consola (útil para debugging)
DB_LOGGING=false

# ============================================
# ORIGEN DE DATOS (MySQL) PARA MIGRACIÓN
# ============================================
# Estas variables solo se usan por scripts/migrate-mysql-to-postgres.js
# Si usas Docker, normalmente será 127.0.0.1:3307
# Si usas MySQL local, suele ser 127.0.0.1:3306
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=almacen_user
MYSQL_PASSWORD=almacen123
MYSQL_DATABASE=almacen

# ============================================
# CONFIGURACIÓN DE SEGURIDAD
# ============================================

# Secreto para firmar tokens JWT
# IMPORTANTE: Cambiar en producción por un valor aleatorio y seguro
JWT_SECRET=super-secret-key-change-in-production-2026

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================

# Entorno de ejecución (development, production, test)
NODE_ENV=development

# Puerto del servidor API
PORT=3000

# ============================================
# INSTRUCCIONES DE USO (PostgreSQL / Supabase)
# ============================================
#
# 1. Copiar este archivo como .env:
#    cp .env.example .env
#
# 2. En .env, configurar DATABASE_URL con tu URL de Supabase, por ejemplo:
#    DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.xxxxx.supabase.co:5432/postgres
#
# 3. Aplicar migraciones SQL si las tienes (carpeta migrations/)
#
# 4. Iniciar el servidor:
#    npm run dev
#
# ============================================
