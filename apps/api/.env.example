# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================

# Host de la base de datos MySQL
DB_HOST=localhost

# Puerto de MySQL (por defecto 3306)
DB_PORT=3306

# Usuario de MySQL
DB_USER=root

# Contraseña de MySQL (dejar vacío si no tiene contraseña)
DB_PASSWORD=

# Nombre de la base de datos
DB_NAME=almacen_db

# Sincronizar esquema automáticamente (true solo en desarrollo)
# ADVERTENCIA: En producción usar 'false' y migraciones
DB_SYNC=true

# Mostrar logs de SQL en consola (útil para debugging)
DB_LOGGING=false

# ============================================
# CONFIGURACIÓN DE SEGURIDAD
# ============================================

# Secreto para firmar tokens JWT
# IMPORTANTE: Cambiar en producción por un valor aleatorio y seguro
JWT_SECRET=super-secret-key-change-in-production-2026

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================

# Entorno de ejecución (development, production, test)
NODE_ENV=development

# Puerto del servidor API
PORT=3000

# ============================================
# INSTRUCCIONES DE USO
# ============================================
# 
# 1. Copiar este archivo como .env:
#    cp .env.example .env
#
# 2. Editar .env con tus valores reales
#
# 3. Crear la base de datos en MySQL:
#    mysql -u root -p
#    CREATE DATABASE almacen_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#    exit;
#
# 4. Iniciar el servidor:
#    npm run dev
#
# ============================================
